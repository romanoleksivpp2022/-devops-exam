variable "do_token" {
  description = "DigitalOcean API Token"
  type        = string
  sensitive   = true
}

variable "region" {
  description = "DigitalOcean region"
  type        = string
  default     = "fra1"
}

variable "prefix" {
  description = "Resource name prefix"
  type        = string
  default     = "oleksiv"
}
